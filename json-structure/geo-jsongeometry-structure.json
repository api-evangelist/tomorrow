{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/tomorrow/refs/heads/main/json-structure/geo-jsongeometry-structure.json",
  "name": "GeoJSONGeometry",
  "description": "GeoJSON geometry \u2014 Point, LineString, or Polygon.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "Point",
        "LineString",
        "Polygon"
      ],
      "example": "Point"
    },
    "coordinates": {
      "type": "array",
      "items": {},
      "example": [
        -71.0466,
        42.3478
      ]
    }
  },
  "required": [
    "type",
    "coordinates"
  ]
}